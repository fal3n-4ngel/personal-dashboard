# Copy this file to .env.local and fill in your own values.
# Nothing here is required at build time — the app also accepts every one of
# these as a per-request header (X-Firebase-Config, X-Trakt-Client-Id, etc.),
# so you can skip this file entirely and self-host as a bring-your-own-config
# API. Setting them as env vars just makes YOUR deployment usable out of the box.

# ─── Firebase (required) ───────────────────────────────────────────────────
# Web App config object from Firebase Console → Project Settings → General,
# collapsed to a single-line JSON string.
FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# ─── Trakt (optional — enables movie/show sync) ────────────────────────────
# Create an app at https://trakt.tv/oauth/applications
# Redirect URI must be: https://<your-domain>/api/auth/trakt/callback
NEXT_PUBLIC_TRAKT_CLIENT_ID=
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# ─── AniList (optional — enables anime sync) ───────────────────────────────
# Create an app at https://anilist.co/settings/developer
# Redirect URI must be: https://<your-domain>
NEXT_PUBLIC_ANILIST_CLIENT_ID=

# ─── TMDb (optional — enriches Trakt results with poster art) ─────────────
# Get a v3 API key at https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=
